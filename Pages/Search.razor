@page "/search"
@using MusicWeb.Components
@inject MusicCatalogService CatalogService
@inject MusicSearchService SearchService
@inject PlaybackService Playback
@inject PlaylistService PlaylistService
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Search - MusicWeb</PageTitle>

<section class="hero-card">
    <div>
        <p class="eyebrow">Search</p>
        <h1>Find your music</h1>
        <p class="hero-copy">Search albums, tracks, artists, and genres.</p>
    </div>
</section>

<section class="search-shell">
    <input class="search-box"
           placeholder="Search..."
           value="@_query"
           @oninput="HandleSearchChanged"/>
    <p class="search-hint">@(_isSearching ? "Searching..." : "Type to search")</p>
</section>

@if (!string.IsNullOrWhiteSpace(_query))
{
    <div class="filter-tabs">
        <button class="filter-tab @(_activeFilter == "all" ? "active" : "")" @onclick='() => SetFilter("all")'>All
        </button>
        <button class="filter-tab @(_activeFilter == "albums" ? "active" : "")" @onclick='() => SetFilter("albums")'>
            Albums
        </button>
        <button class="filter-tab @(_activeFilter == "tracks" ? "active" : "")" @onclick='() => SetFilter("tracks")'>
            Tracks
        </button>
        <button class="filter-tab @(_activeFilter == "artists" ? "active" : "")" @onclick='() => SetFilter("artists")'>
            Artists
        </button>
        <button class="filter-tab @(_activeFilter == "genres" ? "active" : "")" @onclick='() => SetFilter("genres")'>
            Genres
        </button>
    </div>

    @if (_isAddToPlaylistMode)
    {
        <div class="playlist-context">
            <span>Adding to playlist: <strong>@_playlistName</strong></span>
            <button class="ghost-button" @onclick="ExitAddToPlaylistMode">Cancel</button>
        </div>
    }

    <section class="content-grid search-results-grid">
        @if (_activeFilter == "all" || _activeFilter == "albums")
        {
            <div class="panel-card wide-panel">
                <div class="section-heading">
                    <h2>Albums</h2>
                    <span>@_searchResults.Albums.Count result(s)</span>
                </div>
                <div class="album-grid">
                    @foreach (var album in _searchResults.Albums)
                    {
                        <article class="album-card">
                            <button class="cover-button" @onclick="() => OpenAlbum(album.AlbumId)">
                                <img src="@CoverUrl(album.CoverImageUrl)" alt="@album.Title"/>
                            </button>
                            <div>
                                <strong>@album.Title</strong>
                                <p>@album.Artist</p>
                                <span>@album.Genre</span>
                            </div>
                            <div class="card-actions">
                                @if (_isAddToPlaylistMode)
                                {
                                    <button class="pill-button" @onclick="() => AddAlbumToPlaylist(album.AlbumId)">Add
                                        Album
                                    </button>
                                }
                                else
                                {
                                    <button class="pill-button" @onclick="() => PlayAlbumAsync(album.AlbumId)">Play
                                    </button>
                                    <button class="ghost-button" @onclick="() => AddAlbumToQueueAsync(album.AlbumId)">
                                        Add to Queue
                                    </button>
                                }
                                <button class="ghost-button" @onclick="() => OpenAlbum(album.AlbumId)">Details</button>
                                <PlaylistSelector
                                    Album="@(new PlaylistSelector.AlbumIdentifier { AlbumId = album.AlbumId })"/>
                            </div>
                        </article>
                    }
                </div>
            </div>
        }

        @if (_activeFilter == "all" || _activeFilter == "tracks")
        {
            <div class="panel-card wide-panel">
                <div class="section-heading">
                    <h2>Tracks</h2>
                    <span>@_searchResults.Tracks.Count result(s)</span>
                </div>
                <div class="track-list">
                    @foreach (var match in _searchResults.Tracks)
                    {
                        <div class="track-row">
                            <span class="track-index"
                                  @onclick="() => PlayTrackAsync(match.AlbumId, match.TrackId)">@match.Index</span>
                            <div class="track-copy" @onclick="() => PlayTrackAsync(match.AlbumId, match.TrackId)">
                                <strong>@match.Title</strong>
                                <span>@match.Artist - @match.AlbumTitle</span>
                            </div>
                            <div style="display: flex; gap: 0.5rem; align-items: center;">
                                <span class="track-meta">@match.Genre</span>
                                @if (_isAddToPlaylistMode)
                                {
                                    <button class="pill-button"
                                            @onclick="() => AddTrackToPlaylist(match.AlbumId, match.TrackId)">Add
                                    </button>
                                }
                                else
                                {
                                    <button class="ghost-button"
                                            @onclick="() => AddTrackToQueueAsync(match.AlbumId, match.TrackId)">➕ Queue
                                    </button>
                                }
                                <PlaylistSelector
                                    Track="@(new PlaylistSelector.TrackIdentifier { AlbumId = match.AlbumId, TrackId = match.TrackId })"/>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        @if (_activeFilter == "all" || _activeFilter == "artists")
        {
            <div class="panel-card wide-panel">
                <div class="section-heading">
                    <h2>Artists</h2>
                    <span>@_artistResults.Count result(s)</span>
                </div>
                <div class="genre-grid">
                    @foreach (var artist in _artistResults)
                    {
                        <button class="genre-card" @onclick="() => GoToArtist(artist.Name)">
                            <span class="genre-name">@artist.Name</span>
                            <span class="genre-count">@artist.AlbumCount albums</span>
                        </button>
                    }
                </div>
            </div>
        }

        @if (_activeFilter == "all" || _activeFilter == "genres")
        {
            <div class="panel-card wide-panel">
                <div class="section-heading">
                    <h2>Genres</h2>
                    <span>@_genreResults.Count result(s)</span>
                </div>
                <div class="genre-grid">
                    @foreach (var genre in _genreResults)
                    {
                        <button class="genre-card" @onclick="() => GoToGenre(genre.Name)">
                            <span class="genre-name">@genre.Name</span>
                            <span class="genre-count">@genre.AlbumCount albums</span>
                        </button>
                    }
                </div>
            </div>
        }
    </section>
}
else
{
    <section class="panel-card wide-panel">
        <div class="section-heading">
            <h2>Browse by Genre</h2>
        </div>
        <div class="genre-grid">
            @foreach (var genre in _topGenres.Take(8))
            {
                <button class="genre-card" @onclick="() => GoToGenre(genre.Key)">
                    <span class="genre-name">@genre.Key</span>
                    <span class="genre-count">@genre.Value albums</span>
                </button>
            }
        </div>
        <div style="margin-top: 2rem;">
            <div class="section-heading">
                <h2>Browse by Artist</h2>
            </div>
            <div class="genre-grid">
                @foreach (var artist in _topArtists.Take(8))
                {
                    <button class="genre-card" @onclick="() => GoToArtist(artist.Key)">
                        <span class="genre-name">@artist.Key</span>
                        <span class="genre-count">@artist.Value albums</span>
                    </button>
                }
            </div>
        </div>
    </section>
}

<style>
    .filter-tabs {
        display: flex;
        gap: 0.5rem;
        margin: 1.5rem 0 1rem;
        flex-wrap: wrap;
    }

    .filter-tab {
        padding: 0.6rem 1.2rem;
        border-radius: 2rem;
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(255, 255, 255, 0.06);
        color: var(--text);
        cursor: pointer;
        transition: all 0.15s;
    }

    .filter-tab:hover {
        background: rgba(255, 255, 255, 0.08);
    }

    .filter-tab.active {
        background: linear-gradient(135deg, #f74f6f, #ffb14b);
        color: #0d0b12;
        font-weight: 600;
        border: none;
    }

    .playlist-context {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0.8rem 1.2rem;
        background: rgba(247, 79, 111, 0.12);
        border-radius: 1rem;
        margin-bottom: 1rem;
    }

    .genre-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
        gap: 1rem;
    }

    .genre-card {
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-radius: 1rem;
        padding: 1.2rem 1rem;
        cursor: pointer;
        transition: all 0.2s;
        text-align: left;
    }

    .genre-card:hover {
        background: rgba(255, 255, 255, 0.08);
        transform: translateY(-2px);
    }

    .genre-name {
        display: block;
        font-weight: 600;
        font-size: 1.1rem;
        margin-bottom: 0.25rem;
    }

    .genre-count {
        font-size: 0.85rem;
        color: var(--muted);
    }
</style>

@code {
    [SupplyParameterFromQuery] public string? AddToPlaylist { get; set; }

    private string? _query;
    private int _searchVersion;
    private bool _isSearching;
    private MusicSearchResult _searchResults = new();
    private string _activeFilter = "all";

    private List<ArtistResult> _artistResults = new();
    private List<GenreResult> _genreResults = new();

    private bool _isAddToPlaylistMode => !string.IsNullOrWhiteSpace(AddToPlaylist);
    private string _playlistId => AddToPlaylist ?? "";
    private string _playlistName = "";

    private Dictionary<string, int> _topGenres = new();
    private Dictionary<string, int> _topArtists = new();

    public class ArtistResult
    {
        public string Name { get; set; } = "";
        public int AlbumCount { get; set; }
    }

    public class GenreResult
    {
        public string Name { get; set; } = "";
        public int AlbumCount { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        if (_isAddToPlaylistMode)
        {
            var playlist = await PlaylistService.GetPlaylistAsync(_playlistId);
            _playlistName = playlist?.Name ?? "Playlist";
        }

        var overview = await CatalogService.GetOverviewAsync();
        _topGenres = overview.Albums
            .SelectMany(a => a.Genre)
            .GroupBy(g => g)
            .ToDictionary(g => g.Key, g => g.Count())
            .OrderByDescending(kv => kv.Value)
            .Take(12)
            .ToDictionary(kv => kv.Key, kv => kv.Value);

        _topArtists = overview.Albums
            .SelectMany(a => a.ArtistName)
            .GroupBy(a => a)
            .ToDictionary(g => g.Key, g => g.Count())
            .OrderByDescending(kv => kv.Value)
            .Take(12)
            .ToDictionary(kv => kv.Key, kv => kv.Value);
    }

    private async Task HandleSearchChanged(ChangeEventArgs args)
    {
        _query = args.Value?.ToString();
        var localVersion = ++_searchVersion;

        if (string.IsNullOrWhiteSpace(_query))
        {
            _isSearching = false;
            _searchResults = new();
            _artistResults.Clear();
            _genreResults.Clear();
            return;
        }

        _isSearching = true;
        await Task.Delay(220);
        if (localVersion != _searchVersion) return;

        _searchResults = await SearchService.SearchAsync(_query);

        var overview = await CatalogService.GetOverviewAsync();
        var queryLower = _query.Trim().ToLower();

        // Search across all artists in the arrays
        var artistMatches = overview.Albums
            .SelectMany(a => a.ArtistName.Select(ar => new { Artist = ar, AlbumId = a.Id }))
            .Where(x => x.Artist.ToLower().Contains(queryLower))
            .GroupBy(x => x.Artist)
            .Select(g => new ArtistResult { Name = g.Key, AlbumCount = g.Select(x => x.AlbumId).Distinct().Count() })
            .OrderByDescending(a => a.AlbumCount)
            .Take(20)
            .ToList();
        _artistResults = artistMatches;

        // Search across all genres in the arrays
        var genreMatches = overview.Albums
            .SelectMany(a => a.Genre.Select(g => new { Genre = g, AlbumId = a.Id }))
            .Where(x => x.Genre.ToLower().Contains(queryLower))
            .GroupBy(x => x.Genre)
            .Select(g => new GenreResult { Name = g.Key, AlbumCount = g.Select(x => x.AlbumId).Distinct().Count() })
            .OrderByDescending(g => g.AlbumCount)
            .Take(20)
            .ToList();
        _genreResults = genreMatches;

        _isSearching = false;
        await InvokeAsync(StateHasChanged);
    }

    private void SetFilter(string filter) => _activeFilter = filter;

    private void ExitAddToPlaylistMode() => Navigation.NavigateTo("/search");

    private async Task AddAlbumToPlaylist(int albumId)
    {
        var album = await CatalogService.GetAlbumAsync(albumId);
        if (album != null)
        {
            foreach (var track in album.Tracks.Where(t => t.HasSource))
                await PlaylistService.AddTrackToPlaylistAsync(_playlistId, track, album);
            await JS.InvokeVoidAsync("alert", $"Added album '{album.DisplayTitle}' to playlist.");
        }
    }

    private async Task AddTrackToPlaylist(int albumId, int trackId)
    {
        var album = await CatalogService.GetAlbumAsync(albumId);
        var track = album?.Tracks.FirstOrDefault(t => t.Id == trackId);
        if (track != null && album != null && track.HasSource)
        {
            await PlaylistService.AddTrackToPlaylistAsync(_playlistId, track, album);
            await JS.InvokeVoidAsync("alert", $"Added track '{track.Title}' to playlist.");
        }
    }

    private async Task PlayAlbumAsync(int albumId)
    {
        var album = await CatalogService.GetAlbumAsync(albumId);
        if (album != null) await Playback.PlayAlbumAsync(album);
    }

    private async Task PlayTrackAsync(int albumId, int trackId)
    {
        var album = await CatalogService.GetAlbumAsync(albumId);
        if (album != null) await Playback.PlayTrackAsync(album, trackId);
    }

    private async Task AddAlbumToQueueAsync(int albumId)
    {
        var album = await CatalogService.GetAlbumAsync(albumId);
        if (album != null)
        {
            var tracks = album.Tracks.Where(t => t.HasSource).ToList();
            if (tracks.Any()) await Playback.AddToQueueAsync(tracks, album);
        }
    }

    private async Task AddTrackToQueueAsync(int albumId, int trackId)
    {
        var album = await CatalogService.GetAlbumAsync(albumId);
        var track = album?.Tracks.FirstOrDefault(t => t.Id == trackId);
        if (track != null && track.HasSource)
            await Playback.AddToQueueAsync(new[] { track }, album);
    }

    private void OpenAlbum(int albumId) => Navigation.NavigateTo($"/album/{albumId}");
    private void GoToArtist(string artist) => Navigation.NavigateTo($"/artist/{Uri.EscapeDataString(artist)}");
    private void GoToGenre(string genre) => Navigation.NavigateTo($"/genre/{Uri.EscapeDataString(genre)}");

    private static string CoverUrl(string? url) => string.IsNullOrWhiteSpace(url) ? "/favicon.png" : url;
}