@page "/artists"
@inject MusicCatalogService CatalogService
@inject NavigationManager Navigation

<PageTitle>Artists - MusicWeb</PageTitle>

<section class="hero-card">
    <div>
        <p class="eyebrow">Browse</p>
        <h1>Artists</h1>
        <p class="hero-copy">Discover music by artist.</p>
    </div>
</section>

@if (_artists == null)
{
    <p>Loading...</p>
}
else
{
    <section class="panel-card wide-panel">
        <div class="section-heading">
            <h2>All Artists</h2>
            <span>@_artists.Count total</span>
        </div>
        <div class="genre-grid">
            @foreach (var artist in _artists)
            {
                <button class="genre-card" @onclick="() => GoToArtist(artist.Key)">
                    <span class="genre-name">@artist.Key</span>
                    <span class="genre-count">@artist.Value albums</span>
                </button>
            }
        </div>
    </section>
}

<style>
    .genre-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
        gap: 1rem;
    }
    .genre-card {
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-radius: 1rem;
        padding: 1.2rem 1rem;
        cursor: pointer;
        transition: all 0.2s;
        text-align: left;
    }
    .genre-card:hover {
        background: rgba(255, 255, 255, 0.08);
        transform: translateY(-2px);
    }
    .genre-name {
        display: block;
        font-weight: 600;
        font-size: 1.1rem;
        margin-bottom: 0.25rem;
    }
    .genre-count {
        font-size: 0.85rem;
        color: var(--muted);
    }
</style>

@code {
    private Dictionary<string, int>? _artists;

    protected override async Task OnInitializedAsync()
    {
        var overview = await CatalogService.GetOverviewAsync();
        _artists = overview.Albums
            .SelectMany(a => a.ArtistName)
            .GroupBy(a => a)
            .ToDictionary(g => g.Key, g => g.Count())
            .OrderByDescending(kv => kv.Value)
            .ToDictionary(kv => kv.Key, kv => kv.Value);
    }

    private void GoToArtist(string artistName)
    {
        Navigation.NavigateTo($"/artist/{Uri.EscapeDataString(artistName)}");
    }
}