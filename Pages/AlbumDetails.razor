@page "/album/{Id:int}"
@using MusicWeb.Components
@inject MusicCatalogService CatalogService
@inject PlaybackService Playback

<PageTitle>@(_album?.DisplayTitle ?? "Album")</PageTitle>

@if (_album is null)
{
    <section class="hero-card loading-card">
        <p class="eyebrow">Album</p>
        <h1>Loading album details...</h1>
    </section>
}
else
{
    <section class="album-hero">
        <img src="@CoverUrl(_album.CoverImageUrl)" alt="@_album.DisplayTitle" />
        <div>
            <p class="eyebrow">Album details</p>
            <h1>@_album.DisplayTitle</h1>
            <p class="album-subtitle">@_album.DisplayArtist</p>
            <p class="hero-copy">@(_album.DescriptionText ?? _album.TitleFa)</p>
            <div class="meta-chips">
                @if (!string.IsNullOrWhiteSpace(_album.Genre))
                {
                    <span>@_album.Genre</span>
                }
                @if (!string.IsNullOrWhiteSpace(_album.Format))
                {
                    <span>@_album.Format</span>
                }
                @if (_album.TracksCount > 0)
                {
                    <span>@_album.TracksCount track(s)</span>
                }
                @if (!string.IsNullOrWhiteSpace(_album.PublishedAt))
                {
                    <span>@_album.PublishedAt</span>
                }
            </div>
            <div class="hero-actions">
                <button class="pill-button" @onclick="() => Playback.PlayAlbumAsync(_album)">Play</button>
                <button class="ghost-button" @onclick="() => AddAlbumToQueueAsync()">Add to Queue</button>
                @if (!string.IsNullOrWhiteSpace(_album.ZipDownloadUrl))
                {
                    <a class="ghost-button link-button" href="@_album.ZipDownloadUrl" target="_blank" rel="noreferrer">Album ZIP</a>
                }
                <PlaylistSelector Album="@(new PlaylistSelector.AlbumIdentifier { AlbumId = _album.Id })" />
            </div>
        </div>
    </section>

    <section class="content-grid album-grid-layout">
        <div class="panel-card wide-panel">
            <div class="section-heading">
                <div>
                    <p class="eyebrow">Track list</p>
                    <h2>@_album.Tracks.Count song(s)</h2>
                </div>
            </div>
            <div class="track-list">
                @foreach (var track in _album.Tracks.OrderBy(track => track.Index))
                {
                    <div class="track-row">
                        <span class="track-index" @onclick="() => Playback.PlayTrackAsync(_album, track.Id)">@track.Index</span>
                        <div class="track-copy" @onclick="() => Playback.PlayTrackAsync(_album, track.Id)">
                            <strong>@track.Title</strong>
                            <span>@(_album.DisplayArtist) - @(_album.DisplayTitle)</span>
                        </div>
                        <div style="display: flex; gap: 0.5rem; align-items: center;">
                            <span class="track-meta">@(track.HasSource ? "Play" : "Missing source")</span>
                            @if (track.HasSource)
                            {
                                <button class="ghost-button" @onclick="() => AddTrackToQueueAsync(track)">➕ Queue</button>
                                <PlaylistSelector Track="@(new PlaylistSelector.TrackIdentifier { AlbumId = _album.Id, TrackId = track.Id })" />
                            }
                        </div>
                    </div>
                }
            </div>
        </div>

        <div class="panel-card">
            <div class="section-heading">
                <div>
                    <p class="eyebrow">About</p>
                    <h2>Release info</h2>
                </div>
            </div>
            <dl class="details-list">
                <div><dt>Likes</dt><dd>@_album.LikeCount</dd></div>
                <div><dt>Comments</dt><dd>@_album.CommentCount</dd></div>
                <div><dt>Dislikes</dt><dd>@_album.DislikeCount</dd></div>
                <div><dt>Release</dt><dd>@(_album.Released ?? "-")</dd></div>
                <div><dt>ZIP size</dt><dd>@(_album.ZipSizeMb is null ? "-" : $"{_album.ZipSizeMb:0.#} MB")</dd></div>
            </dl>

            @if (_album.Categories.Count > 0)
            {
                <div class="tag-cluster">
                    <p class="eyebrow">Categories</p>
                    @foreach (var category in _album.Categories)
                    {
                        <span>@category</span>
                    }
                </div>
            }

            @if (_album.Tags.Count > 0)
            {
                <div class="tag-cluster">
                    <p class="eyebrow">Tags</p>
                    @foreach (var tag in _album.Tags.Take(18))
                    {
                        <span>@tag</span>
                    }
                </div>
            }
        </div>
    </section>
}

@code {
    [Parameter] public int Id { get; set; }

    private MusicAlbum? _album;

    protected override async Task OnParametersSetAsync()
    {
        _album = await CatalogService.GetAlbumAsync(Id);
    }

    private async Task AddAlbumToQueueAsync()
    {
        if (_album != null)
        {
            var tracks = _album.Tracks.Where(t => t.HasSource).ToList();
            if (tracks.Count > 0)
                await Playback.AddToQueueAsync(tracks, _album);
        }
    }

    private async Task AddTrackToQueueAsync(MusicTrack track)
    {
        if (track.HasSource)
            await Playback.AddToQueueAsync(new[] { track });
    }

    private static string CoverUrl(string? coverImageUrl) =>
        string.IsNullOrWhiteSpace(coverImageUrl) ? "/favicon.png" : coverImageUrl;
}