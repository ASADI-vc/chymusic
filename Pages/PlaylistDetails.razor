@page "/playlist/{Id}"
@inject PlaylistService PlaylistService
@inject PlaybackService Playback
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>@(_playlist?.Name ?? "Playlist") - MusicWeb</PageTitle>

@if (_playlist == null)
{
    <p>Loading...</p>
}
else
{
    <section class="album-hero">
        <img src="@(_playlist.CoverImageUrl ?? "/favicon.png")" alt="@_playlist.Name" />
        <div>
            <p class="eyebrow">Playlist</p>
            <h1>@_playlist.Name</h1>
            @if (!string.IsNullOrWhiteSpace(_playlist.Description))
            {
                <p class="album-subtitle">@_playlist.Description</p>
            }
            <div class="meta-chips">
                <span>@_playlist.Tracks.Count tracks</span>
                <span>Created @_playlist.CreatedAt.ToString("d")</span>
            </div>
            <div class="hero-actions">
                <button class="pill-button" @onclick="PlayAll">Play All</button>
                <button class="ghost-button" @onclick="EditDetails">Edit Details</button>
                <button class="ghost-button" @onclick="DeletePlaylist">Delete</button>
            </div>
        </div>
    </section>

    <section class="panel-card wide-panel">
        <div class="section-heading">
            <h2>Tracks</h2>
            <button class="ghost-button" @onclick="AddTracks">+ Add Tracks</button>
        </div>

        <div class="track-list">
            @for (int i = 0; i < _playlist.Tracks.Count; i++)
            {
                var track = _playlist.Tracks[i];
                var index = i;
                <div class="track-row">
                    <span class="track-index">@(i+1)</span>
                    <div class="track-copy">
                        <strong>@track.Title</strong>
                        <span>@track.Artist - @track.AlbumTitle</span>
                    </div>
                    <div style="display: flex; gap: 0.5rem;">
                        <button class="ghost-button" @onclick="() => PlayTrack(index)">▶</button>
                        <button class="ghost-button" @onclick="() => RemoveTrack(track.TrackId)">✕</button>
                    </div>
                </div>
            }
        </div>
    </section>
}

@code {
    [Parameter] public string Id { get; set; } = string.Empty;

    private Playlist? _playlist;

    protected override async Task OnInitializedAsync()
    {
        await LoadPlaylist();
    }

    private async Task LoadPlaylist()
    {
        _playlist = await PlaylistService.GetPlaylistAsync(Id);
    }

    private async Task PlayAll()
    {
        if (_playlist != null)
            await Playback.PlayPlaylistAsync(_playlist);
    }

    private async Task PlayTrack(int index)
    {
        if (_playlist != null)
            await Playback.PlayPlaylistAsync(_playlist, index);
    }

    private async Task RemoveTrack(int trackId)
    {
        if (_playlist == null) return;
        if (await PlaylistService.RemoveTrackFromPlaylistAsync(Id, trackId))
        {
            await LoadPlaylist();
            StateHasChanged();
        }
    }

    private async Task EditDetails()
    {
        var name = await JS.InvokeAsync<string>("prompt", "Edit playlist name:", _playlist!.Name);
        if (!string.IsNullOrWhiteSpace(name))
        {
            _playlist.Name = name;
            var desc = await JS.InvokeAsync<string>("prompt", "Description (optional):", _playlist.Description);
            _playlist.Description = desc;
            await PlaylistService.SavePlaylistAsync(_playlist);
            StateHasChanged();
        }
    }

    private async Task DeletePlaylist()
    {
        if (!await JS.InvokeAsync<bool>("confirm", "Delete this playlist?")) return;
        await PlaylistService.DeletePlaylistAsync(Id);
        Navigation.NavigateTo("/playlists");
    }

    private void AddTracks()
    {
        // Open a modal or navigate to search page with "add to playlist" mode
        Navigation.NavigateTo($"/search?addToPlaylist={Id}");
    }
}