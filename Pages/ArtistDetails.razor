@page "/artist/{ArtistName}"
@inject MusicCatalogService CatalogService
@inject PlaybackService Playback
@inject NavigationManager Navigation

<PageTitle>@ArtistName - MusicWeb</PageTitle>

@if (_albums == null)
{
    <p>Loading...</p>
}
else
{
    <section class="hero-card">
        <div>
            <p class="eyebrow">Artist</p>
            <h1>@ArtistName</h1>
            <p class="hero-copy">@_albums.Count albums • @_tracks.Count tracks</p>
        </div>
    </section>

    <section class="content-grid">
        <div class="panel-card wide-panel">
            <div class="section-heading">
                <h2>Albums</h2>
            </div>
            <div class="album-grid">
                @foreach (var album in _albums)
                {
                    <article class="album-card">
                        <button class="cover-button" @onclick="() => OpenAlbum(album.Id)">
                            <img src="@CoverUrl(album.CoverImageUrl)" alt="@album.DisplayTitle" />
                        </button>
                        <div>
                            <strong>@album.DisplayTitle</strong>
                            <p>@album.DisplayArtist</p>
                        </div>
                        <div class="card-actions">
                            <button class="pill-button" @onclick="() => PlayAlbumAsync(album.Id)">Play</button>
                            <button class="ghost-button" @onclick="() => OpenAlbum(album.Id)">Details</button>
                        </div>
                    </article>
                }
            </div>
        </div>

        <div class="panel-card wide-panel">
            <div class="section-heading">
                <h2>Popular Tracks</h2>
            </div>
            <div class="track-list">
                @foreach (var track in _tracks.Take(20))
                {
                    <div class="track-row">
                        <span class="track-index">@track.Index</span>
                        <div class="track-copy">
                            <strong>@track.Title</strong>
                            <span>@track.Artist - @track.AlbumTitle</span>
                        </div>
                        <div style="display: flex; gap: 0.5rem;">
                            <button class="ghost-button" @onclick="() => PlayTrackAsync(track.AlbumId, track.TrackId)">▶</button>
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>
}

@code {
    [Parameter] public string ArtistName { get; set; } = string.Empty;

    private List<MusicAlbumSummary> _albums = new();
    private List<MusicTrackSummary> _tracks = new();

    protected override async Task OnParametersSetAsync()
    {
        var decoded = Uri.UnescapeDataString(ArtistName);
        _albums = await CatalogService.GetAlbumsByArtistAsync(decoded);
        _tracks = await CatalogService.GetTracksByArtistAsync(decoded);
    }

    private async Task PlayAlbumAsync(int albumId)
    {
        var album = await CatalogService.GetAlbumAsync(albumId);
        if (album != null) await Playback.PlayAlbumAsync(album);
    }

    private async Task PlayTrackAsync(int albumId, int trackId)
    {
        var album = await CatalogService.GetAlbumAsync(albumId);
        if (album != null) await Playback.PlayTrackAsync(album, trackId);
    }

    private void OpenAlbum(int albumId) => Navigation.NavigateTo($"/album/{albumId}");

    private static string CoverUrl(string? url) =>
        string.IsNullOrWhiteSpace(url) ? "/favicon.png" : url;
}