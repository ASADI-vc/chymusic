# CHYMUSIC Admin API — environment variables.
# Copy to .env and edit before first run.

CHYMUSIC_ENVIRONMENT=dev
CHYMUSIC_DEBUG=true
CHYMUSIC_LOG_LEVEL=INFO

CHYMUSIC_HOST=0.0.0.0
CHYMUSIC_PORT=8001
# Comma-separated list of allowed CORS origins.
CHYMUSIC_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000","http://localhost:5173"]

# Database. SQLite by default — switch to postgres for production.
CHYMUSIC_DATABASE_URL=sqlite:///data/admin.sqlite

# Auth — GENERATE A REAL SECRET: openssl rand -hex 32
CHYMUSIC_JWT_SECRET=CHANGE_ME_IN_PRODUCTION
CHYMUSIC_JWT_ALGORITHM=HS256
CHYMUSIC_JWT_EXPIRY_MINUTES=1440

# Bootstrap admin (only used on first run to create the first user).
CHYMUSIC_BOOTSTRAP_ADMIN_USERNAME=admin
CHYMUSIC_BOOTSTRAP_ADMIN_PASSWORD=changeme

# Scrapers
CHYMUSIC_SCRAPER_USER_AGENT=Mozilla/5.0 (compatible; CHYMUSIC-admin/0.1; +https://github.com/ASADI-vc/chymusic)
CHYMUSIC_SCRAPER_CONCURRENCY=4
CHYMUSIC_SCRAPER_REQUEST_TIMEOUT_SEC=30
CHYMUSIC_SCRAPER_DELAY_SEC=0.5

# Catalog export
CHYMUSIC_CATALOG_PAGE_SIZE=200

# Extension ingest
CHYMUSIC_EXTENSION_INGEST_ENABLED=true
CHYMUSIC_EXTENSION_INGEST_API_KEY=CHANGE_ME
