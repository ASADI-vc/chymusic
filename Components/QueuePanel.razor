@implements IDisposable
@inject PlaybackService Playback

<div class="queue-panel @(_isExpanded ? "is-expanded" : "")">
    <div class="queue-header" @onclick="ToggleExpanded">
        <div class="queue-header-left">
            <span class="eyebrow">Queue</span>
            <span class="queue-count">@Playback.Queue.Count </span>
        </div>
        <div class="queue-header-right">
            <button class="text-button" @onclick="() => Playback.ClearQueue()" @onclick:stopPropagation="true" title="Clear queue">
                Clear
            </button>
            <span class="expand-icon">@(_isExpanded ? "▼" : "▲")</span>
        </div>
    </div>

    @if (_isExpanded && Playback.Queue.Count > 0)
    {
        <div class="queue-list">
            @for (int i = 0; i < Playback.Queue.Count; i++)
            {
                var track = Playback.Queue[i];
                var index = i;
                var isCurrent = i == Playback.QueueIndex;
                <div class="queue-item @(isCurrent ? "current" : "")">
                    <div class="queue-item-info" 
                         @onclick="() => Playback.SkipToQueueItemAsync(index)"
                         title="@($"{track.Title}\n{track.Artist} • {track.AlbumTitle}")">
                        <span class="queue-index">@(i + 1)</span>
                        <img src="@CoverUrl(track.CoverImageUrl)" alt="" class="queue-thumb" />
                        <div class="queue-track">
                            <strong>@track.Title</strong>
                            <span>@track.Artist - @track.AlbumTitle</span>
                        </div>
                    </div>
                    <button class="remove-button" @onclick="() => Playback.RemoveFromQueue(index)"
                            title="Remove from queue">
                        <span>✕</span>
                    </button>
                </div>
            }
        </div>
    }
</div>

<style>
    .queue-panel {
        display: flex;
        flex-direction: column;
        width: 100%;
        background: transparent;
        border: none;
        border-radius: 1.2rem;
        overflow: hidden;
        transition: max-height 0.3s ease;
        height: auto;
    }

    .queue-panel:not(.is-expanded) {
        max-height: 3.8rem;
    }

    .queue-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0.75rem 0.5rem;
        cursor: pointer;
        user-select: none;
        border-bottom: 1px solid transparent;
        transition: border-color 0.2s;
        flex-shrink: 0;
    }

    .queue-panel.is-expanded .queue-header {
        border-bottom-color: rgba(255, 255, 255, 0.08);
    }

    .queue-header-left {
        display: flex;
        align-items: baseline;
        gap: 0.75rem;
    }

    .queue-count {
        font-size: 0.8rem;
        font-weight: 500;
        color: rgba(255, 255, 255, 0.5);
        letter-spacing: 0.02em;
    }

    .queue-header-right {
        display: flex;
        align-items: center;
        gap: 0.4rem;
    }

    .icon-button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 2rem;
        height: 2rem;
        border-radius: 0.8rem;
        background: transparent;
        border: none;
        color: rgba(255, 255, 255, 0.7);
        font-size: 1.1rem;
        cursor: pointer;
        transition: all 0.15s ease;
    }

    .icon-button:hover {
        background: rgba(255, 255, 255, 0.08);
        color: white;
        transform: scale(1.05);
    }

    .text-button {
        padding: 0.4rem 0.8rem;
        border-radius: 2rem;
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(255, 255, 255, 0.06);
        color: rgba(255, 255, 255, 0.7);
        font-size: 0.8rem;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.15s ease;
    }

    .text-button:hover {
        background: rgba(255, 255, 255, 0.08);
        color: white;
        border-color: rgba(255, 177, 75, 0.3);
    }

    .shuffle-indicator, .repeat-indicator {
        opacity: 0.5;
        transition: all 0.2s ease;
        font-size: 1.1rem;
    }

    .shuffle-indicator.active, .repeat-indicator.active {
        opacity: 1;
        color: #ffb14b;
        text-shadow: 0 0 8px rgba(255, 177, 75, 0.4);
    }

    .expand-icon {
        font-size: 0.75rem;
        margin-left: 0.5rem;
        opacity: 0.6;
        transition: transform 0.2s;
    }

    .queue-panel.is-expanded .expand-icon {
        transform: rotate(180deg);
    }

    .queue-list {
        flex: 1;
        overflow-y: auto;
        padding: 0.3rem 0.2rem 0.5rem 0;
        scrollbar-width: thin;
        scrollbar-color: rgba(255, 255, 255, 0.2) transparent;
    }

    .queue-list::-webkit-scrollbar {
        width: 4px;
    }

    .queue-list::-webkit-scrollbar-thumb {
        background: rgba(255, 255, 255, 0.2);
        border-radius: 4px;
    }

    .queue-item {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.5rem 0.5rem;
        margin-bottom: 0.2rem;
        border-radius: 0.8rem;
        background: transparent;
        transition: all 0.2s ease;
    }

    .queue-item:hover {
        background: rgba(255, 255, 255, 0.04);
    }

    .queue-item.current {
        background: linear-gradient(135deg, rgba(247, 79, 111, 0.12), rgba(255, 177, 75, 0.06));
        border-left: 3px solid #f74f6f;
        padding-left: calc(0.5rem - 3px);
    }

    .queue-item-info {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        flex: 1;
        cursor: pointer;
        min-width: 0;
    }

    .queue-index {
        width: 1.6rem;
        text-align: center;
        color: rgba(255, 255, 255, 0.45);
        font-size: 0.8rem;
        font-weight: 500;
    }

    .queue-item.current .queue-index {
        color: #f74f6f;
        font-weight: 600;
    }

    .queue-thumb {
        width: 2.2rem;
        height: 2.2rem;
        border-radius: 0.5rem;
        object-fit: cover;
        box-shadow: 0 2px 6px rgba(0, 0, 0, 0.2);
        transition: transform 0.2s;
    }

    .queue-item:hover .queue-thumb {
        transform: scale(1.05);
    }

    .queue-track {
        min-width: 0;
        flex: 1;
    }

    .queue-track strong {
        display: block;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        font-size: 0.9rem;
        font-weight: 600;
        color: rgba(255, 255, 255, 0.95);
    }

    .queue-track span {
        display: block;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        font-size: 0.75rem;
        color: rgba(255, 255, 255, 0.55);
    }

    .remove-button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 1.8rem;
        height: 1.8rem;
        border-radius: 0.5rem;
        background: transparent;
        border: none;
        color: rgba(255, 255, 255, 0.4);
        font-size: 0.9rem;
        cursor: pointer;
        transition: all 0.15s ease;
        opacity: 0;
    }

    .queue-item:hover .remove-button {
        opacity: 1;
    }

    .remove-button:hover {
        background: rgba(247, 79, 111, 0.2);
        color: #f74f6f;
    }
</style>

@code {
    private bool _isExpanded = true;

    protected override void OnInitialized()
    {
        Playback.QueueChanged += OnQueueChanged;
        Playback.StateChanged += OnStateChanged;
    }

    private void OnQueueChanged() => InvokeAsync(StateHasChanged);
    private void OnStateChanged() => InvokeAsync(StateHasChanged);

    private void ToggleExpanded() => _isExpanded = !_isExpanded;

    private void CycleRepeatMode()
    {
        Playback.RepeatMode = Playback.RepeatMode switch
        {
            RepeatMode.Off => RepeatMode.Queue,
            RepeatMode.Queue => RepeatMode.Track,
            RepeatMode.Track => RepeatMode.Off,
            _ => RepeatMode.Off
        };
    }

    private string GetRepeatIcon() => Playback.RepeatMode switch
    {
        RepeatMode.Track => "🔂",
        RepeatMode.Queue => "🔁",
        _ => "🔁"
    };

    private string GetRepeatTitle() => Playback.RepeatMode switch
    {
        RepeatMode.Off => "Repeat: Off",
        RepeatMode.Queue => "Repeat: Queue",
        RepeatMode.Track => "Repeat: Track",
        _ => "Repeat"
    };

    private static string CoverUrl(string? coverImageUrl) =>
        string.IsNullOrWhiteSpace(coverImageUrl) ? "/favicon.png" : coverImageUrl;

    public void Dispose()
    {
        Playback.QueueChanged -= OnQueueChanged;
        Playback.StateChanged -= OnStateChanged;
    }

}