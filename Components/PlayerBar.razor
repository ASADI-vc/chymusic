@implements IDisposable
@inject PlaybackService Playback

<div class="player-shell @(Playback.CurrentTrack is null ? "is-empty" : string.Empty)">
    @if (Playback.CurrentTrack is null || Playback.CurrentAlbum is null)
    {
        <div class="player-empty">
            <div>
                <p class="eyebrow">Ready to listen</p>
                <strong>Pick any track or album to start streaming.</strong>
            </div>
        </div>
    }
    else
    {
        <div class="player-now">
            <img src="@CoverUrl(Playback.CurrentAlbum.CoverImageUrl)" alt="@Playback.CurrentAlbum.DisplayTitle"/>
            <div>
                <p class="eyebrow">Now playing</p>
                <strong>@Playback.CurrentTrack.Title</strong>
                <span>@Playback.CurrentAlbum.DisplayArtist - @Playback.CurrentAlbum.DisplayTitle</span>
                @if (Playback.PlaybackBlocked && !string.IsNullOrWhiteSpace(Playback.PlaybackError))
                {
                    <span class="player-warning">@Playback.PlaybackError</span>
                }
            </div>
        </div>

        <div class="player-middle">
            <div class="player-controls">
                <button class="icon-btn" @onclick="() => Playback.ShuffleEnabled = !Playback.ShuffleEnabled"
                        title="Shuffle">
                    <svg viewBox="0 0 24 24" width="20" height="20" class="@(Playback.ShuffleEnabled ? "active" : "")">
                        <path fill="currentColor"
                              d="M10.59 9.17L5.41 4 4 5.41l5.17 5.17 1.42-1.41zM14.5 4l2.04 2.04L4 18.59 5.41 20 17.96 7.46 20 9.5V4h-5.5zm.33 9.41l-1.41 1.41 3.13 3.13L14.5 20H20v-5.5l-2.04 2.04-3.13-3.13z"/>
                    </svg>
                </button>
                <button class="icon-btn" @onclick="Playback.PlayPreviousAsync" disabled="@(!Playback.HasPrevious)"
                        title="Previous">
                    <svg viewBox="0 0 24 24" width="20" height="20">
                        <path fill="currentColor" d="M6 6h2v12H6V6zm3.5 6l8.5 6V6l-8.5 6z"/>
                    </svg>
                </button>
                <button class="icon-btn" @onclick="Playback.PlayNextAsync" disabled="@(!Playback.HasNext)" title="Next">
                    <svg viewBox="0 0 24 24" width="20" height="20">
                        <path fill="currentColor" d="M6 18l8.5-6L6 6v12zM16 6v12h2V6h-2z"/>
                    </svg>
                </button>
                <button class="icon-btn" @onclick="CycleRepeatMode" title="@GetRepeatTitle()">
                    @if (Playback.RepeatMode == RepeatMode.Track)
                    {
                        <svg viewBox="0 0 24 24" width="20" height="20" class="active">
                            <path fill="currentColor"
                                  d="M7 7h10v3l4-4-4-4v3H5v6h2V7zm10 10H7v-3l-4 4 4 4v-3h12v-6h-2v4z"/>
                            <text x="17" y="17" font-size="10" font-weight="bold" fill="currentColor"
                                  text-anchor="middle">1
                            </text>
                        </svg>
                    }
                    else
                    {
                        <svg viewBox="0 0 24 24" width="20" height="20"
                             class="@(Playback.RepeatMode == RepeatMode.Queue ? "active" : "")">
                            <path fill="currentColor"
                                  d="M7 7h10v3l4-4-4-4v3H5v6h2V7zm10 10H7v-3l-4 4 4 4v-3h12v-6h-2v4z"/>
                        </svg>
                    }
                </button>
                <span class="cache-icon" title="@GetCacheTooltip()">
                    @if (Playback.IsCached)
                    {
                        <svg viewBox="0 0 24 24" width="18" height="18" class="cached">
                            <path fill="currentColor"
                                  d="M19 12v7H5v-7H3v7c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2v-7h-2zm-6 .67l2.59-2.58L17 11.5l-5 5-5-5 1.41-1.41L11 12.67V3h2v9.67z"/>
                        </svg>
                    }
                    else if (Playback.IsCaching)
                    {
                        <div class="download-progress">
                            <svg viewBox="0 0 24 24" width="18" height="18" class="caching-spinner">
                                <path fill="currentColor"
                                      d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8z"/>
                                <path fill="currentColor" d="M12 4v2c3.31 0 6 2.69 6 6h2c0-4.41-3.59-8-8-8z"/>
                            </svg>
                            <span class="download-percent">@(_downloadPercent.ToString("0"))%</span>
                        </div>
                    }
                    else
                    {
                        <svg viewBox="0 0 24 24" width="18" height="18">
                            <path fill="currentColor" d="M4 12l1.41 1.41L11 7.83V20h2V7.83l5.58 5.59L20 12l-8-8-8 8z"/>
                        </svg>
                    }
                </span>
                @if (!string.IsNullOrWhiteSpace(Playback.CurrentTrack.PreferredUrl))
                {
                    <a class="icon-btn" href="@Playback.CurrentTrack.PreferredUrl" target="_blank" rel="noreferrer"
                       title="Open file">
                        <svg viewBox="0 0 24 24" width="18" height="18">
                            <path fill="currentColor"
                                  d="M19 19H5V5h7V3H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2v-7h-2v7zM14 3v2h3.59l-9.83 9.83 1.41 1.41L19 6.41V10h2V3h-7z"/>
                        </svg>
                    </a>
                }
            </div>
            <div class="player-audio">
                <AudioPlayer Source="@Playback.CurrentSourceUrl"
                             OnEnded="HandleEnded"
                             OnError="HandleError"
                             OnBufferedUpdate="UpdateDownloadProgress"/>
            </div>
        </div>
    }
</div>

<style>
    .player-middle {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        flex: 1;
        min-width: 0;
    }

    .player-controls {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
    }

    .icon-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 2.2rem;
        height: 2.2rem;
        border-radius: 0.8rem;
        background: transparent;
        border: none;
        color: rgba(255, 255, 255, 0.7);
        font-size: 1.2rem;
        cursor: pointer;
        transition: all 0.15s ease;
        text-decoration: none;
    }

    .icon-btn:hover:not(:disabled) {
        background: rgba(255, 255, 255, 0.08);
        color: white;
    }

    .icon-btn:disabled {
        opacity: 0.4;
        cursor: not-allowed;
    }

    .icon-btn .active {
        color: #ffb14b;
    }

    .cache-icon {
        font-size: 1.2rem;
        opacity: 0.7;
    }

    .cache-icon.cached {
        opacity: 1;
        color: #7ed585;
    }

    .caching-spinner {
        animation: spin 1.2s linear infinite;
        transform-origin: center;
    }

    @@keyframes spin {
        from {
            transform: rotate(0deg);
        }
        to {
            transform: rotate(360deg);
        }
    }

    .cache-icon svg {
        opacity: 0.7;
        transition: opacity 0.2s;
    }

    .cache-icon .cached {
        opacity: 1;
        color: #7ed585;
    }

    .cache-icon .caching-spinner {
        opacity: 0.9;
        color: #ffb14b;
    }

    .download-progress {
        position: relative;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    .download-percent {
        position: absolute;
        font-size: 7px;
        font-weight: bold;
        color: #ffb14b;
        text-shadow: 0 0 4px rgba(0, 0, 0, 0.5);
    }
</style>

@code {
    private double _downloadPercent;

    protected override void OnInitialized()
    {
        Playback.StateChanged += HandlePlaybackChanged;
    }

    private void HandlePlaybackChanged() => InvokeAsync(StateHasChanged);

    private async Task HandleEnded() => await Playback.HandleTrackEndedAsync();
    private Task HandleError() => Playback.ReportPlaybackErrorAsync();

    private void UpdateDownloadProgress(double percent)
    {
        _downloadPercent = percent;
        InvokeAsync(StateHasChanged);
    }

    private string GetCacheTooltip()
    {
        if (Playback.IsCached) return "Cached";
        if (Playback.IsCaching) return $"Downloading... {_downloadPercent:0}%";
        return "Streaming";
    }

    private void CycleRepeatMode()
    {
        Playback.RepeatMode = Playback.RepeatMode switch
        {
            RepeatMode.Off => RepeatMode.Queue,
            RepeatMode.Queue => RepeatMode.Track,
            RepeatMode.Track => RepeatMode.Off,
            _ => RepeatMode.Off
        };
    }

    private string GetRepeatIcon() => Playback.RepeatMode switch
    {
        RepeatMode.Track => "🔂",
        RepeatMode.Queue => "🔁",
        _ => "🔁"
    };

    private string GetRepeatTitle() => Playback.RepeatMode switch
    {
        RepeatMode.Off => "Repeat: Off",
        RepeatMode.Queue => "Repeat: Queue",
        RepeatMode.Track => "Repeat: Track",
        _ => "Repeat"
    };

    private static string CoverUrl(string? coverImageUrl) =>
        string.IsNullOrWhiteSpace(coverImageUrl) ? "/favicon.png" : coverImageUrl;

    public void Dispose()
    {
        Playback.StateChanged -= HandlePlaybackChanged;
    }

}