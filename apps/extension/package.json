{
  "name": "@chymusic/extension",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite build --watch --mode development",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "clean": "rm -rf dist .turbo",
    "package": "pnpm build && cd dist && zip -r ../chymusic-extension.zip ."
  },
  "dependencies": {
    "@chymusic/shared": "workspace:*",
    "idb-keyval": "^6.2.1",
    "nanoid": "^5.0.7"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.28",
    "@types/chrome": "^0.0.270",
    "typescript": "^5.6.0",
    "vite": "^5.4.8"
  }
}
